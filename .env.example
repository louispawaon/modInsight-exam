RECEIPTS_DIR=Notes/receipt_samples_100
PARSED_OUTPUT_PATH=data/parsed_receipts.jsonl
INDEX_MANIFEST_PATH=data/index_manifest.json
QDRANT_PATH=data/qdrant
QDRANT_COLLECTION=receipt_chunks

CHUNKING_STRATEGY=hybrid
MAX_CHUNK_CHARS=1200

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_INTENT_TIMEOUT_S=20
OLLAMA_ANSWER_TIMEOUT_S=12

DATE_PARSE_ORDER=mdy
DATE_AMBIGUITY_STRATEGY=flag

RETRIEVAL_K=12
RETRIEVAL_SPARSE_THRESHOLD=4
ANSWER_STYLE=hybrid
LOG_LEVEL=INFO

